<?xml version="1.0" encoding="UTF-8"?>
<!--TODO(HECHO): Añadir una vista de búsqueda-->
<odoo>
    <data>
        
        <record model="ir.ui.view" id="g5_customer_tree_view">
            <field name="name">g5.customer.tree</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <tree string="Customer">
                    <field name="name"/>
                    <field name="login" string="Email"/> <field name="city"/>
                    <field name="street"/>
                    <field name="state_id"/>
                    <field name="zip"/>
                    <field name="phone"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="g5_customer_form_view">
            <field name="name">g5.customer.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_simple_form"/>
            <field name="arch" type="xml">
                <group name="phone_numbers" position="replace">
                    <group>
                        <group>
                            <field name="city"/>
                            <field name="street"/>
                            <field name="zip"/>
                        </group>
                        <group>
                            <field name="country_id"/>
                            <field name="state_id"/>
                            <field name="mobile"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Accounts" name="detalle-cuentas">
                            <field name="g5_account_ids"/>
                        </page>
                    </notebook>  
                </group>   
            </field>
        </record>

        <record model="ir.ui.view" id="g5_customer_search_view">
            <field name="name">g5.customer.search</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <search string="Search Customers">
                    <field name="name" filter_domain="['|', ('name', 'ilike', self), ('login', 'ilike', self)]" string="Name or Email"/>
                    
                    <field name="city"/>
                    <field name="zip"/>
                    <field name="phone"/>
                    
                    <group expand="1" string="Group By">
                        <filter string="City" name="group_by_city" context="{'group_by':'city'}"/>
                        <filter string="State" name="group_by_state" context="{'group_by':'state_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="g5_customer_action">
            <field name="name">Customers</field>    
            <field name="res_model">res.users</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="g5_customer_search_view"/>
            <field name="context">{'search_default_group_by_city': 0}</field> </record>

        <menuitem id="customer_menu_id" 
                  name="Customers" 
                  parent="bank_main_menu" 
                  action="g5_customer_action"/>
    </data>
</odoo>

